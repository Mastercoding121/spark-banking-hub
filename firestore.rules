rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: Users can read/write only their own
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User accounts (checking/savings): Only owner can access
    match /accounts/{accountId} {
      allow read, write: if request.auth != null && exists(/databases/$(database)/documents/accounts/$(accountId)) && get(/databases/$(database)/documents/accounts/$(accountId)).data.userId == request.auth.uid;
    }

    // Transactions: Only owner can access
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null && exists(/databases/$(database)/documents/transactions/$(transactionId)) && get(/databases/$(database)/documents/transactions/$(transactionId)).data.userId == request.auth.uid;
    }

    // Sessions: Only the session creator can delete (optional, for secure logout)
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && exists(/databases/$(database)/documents/sessions/$(sessionId)) && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
    }

    // Investment positions: Only owner
    match /investmentPositions/{positionId} {
      allow read, write: if request.auth != null && exists(/databases/$(database)/documents/investmentPositions/$(positionId)) && get(/databases/$(database)/documents/investmentPositions/$(positionId)).data.userId == request.auth.uid;
    }

    // OTP Codes: Anyone can create, only the associated email can use
    match /otpCodes/{email} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email == email;
    }

    // Loan applications: Anyone can create, only the applicant can read
    match /loanApplications/{loanId} {
      allow create: if true;
      allow read: if request.auth != null && (exists(/databases/$(database)/documents/loanApplications/$(loanId)) && get(/databases/$(database)/documents/loanApplications/$(loanId)).data.email == request.auth.token.email);
    }

    // Support tickets: Creator can read, admins can manage
    match /supportTickets/{ticketId} {
      allow read, write: if request.auth != null && (
        (exists(/databases/$(database)/documents/supportTickets/$(ticketId)) && get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == request.auth.uid) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // Support messages: Ticket owner or admin can read/write
    match /supportMessages/{messageId} {
      allow read, write: if request.auth != null && (
        (exists(/databases/$(database)/documents/supportMessages/$(messageId)) && exists(/databases/$(database)/documents/supportTickets/$(get(/databases/$(database)/documents/supportMessages/$(messageId)).data.ticketId)) && (
          get(/databases/$(database)/documents/supportTickets/$(get(/databases/$(database)/documents/supportMessages/$(messageId)).data.ticketId)).data.userId == request.auth.uid ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
        ))
      );
    }

    // Feature flags: Anyone can read, only admins can write
    match /featureFlags/{flagId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Grants: Anyone can read, only admins can write
    match /grants/{grantId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Grant applications: Logged in users can create, applicant can read, admins can manage
    match /grantApplications/{applicationId} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && (
        (exists(/databases/$(database)/documents/grantApplications/$(applicationId)) && get(/databases/$(database)/documents/grantApplications/$(applicationId)).data.userId == request.auth.uid) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }
  }
}
